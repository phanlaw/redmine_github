<%
  project = version.project
  repos   = Repository::Github.where(project: project)
%>
<% if repos.any? %>
  <%
    stats = RedmineGithub::SprintGithubStats.new(version).call
  %>
  <div id="github-sprint-stats">
    <h3><%= l(:label_github_sprint_stats) %></h3>
    <div class="github-stats-grid">
      <div class="github-stat-card">
        <span class="github-stat-value"><%= stats[:merged_pr_count] %></span>
        <span class="github-stat-label"><%= l(:label_github_prs_merged) %></span>
        <% if stats[:open_pr_count] > 0 %>
          <span class="github-stat-sub"><%= stats[:open_pr_count] %> <%= l(:label_github_prs_open) %></span>
        <% end %>
      </div>
      <div class="github-stat-card">
        <span class="github-stat-value"><%= stats[:commit_count] %></span>
        <span class="github-stat-label"><%= l(:label_github_commits) %></span>
      </div>
      <div class="github-stat-card">
        <span class="github-stat-value"><%= stats[:contributors].size %></span>
        <span class="github-stat-label"><%= l(:label_github_contributors) %></span>
        <% if stats[:contributors].any? %>
          <span class="github-stat-sub"><%= stats[:contributors].first(3).join(', ') %><%= stats[:contributors].size > 3 ? '…' : '' %></span>
        <% end %>
      </div>
      <% if stats[:avg_cycle_time_hours] %>
      <div class="github-stat-card">
        <span class="github-stat-value"><%= stats[:avg_cycle_time_hours] %>h</span>
        <span class="github-stat-label"><%= l(:label_github_avg_cycle_time) %></span>
        <% if stats[:avg_review_time_hours] %>
          <span class="github-stat-sub"><%= l(:label_github_review_time) %>: <%= stats[:avg_review_time_hours] %>h</span>
        <% end %>
      </div>
      <% end %>
      <div class="github-stat-card">
        <span class="github-stat-value"><%= stats[:issues_with_pr] %> / <%= version.fixed_issues.count %></span>
        <span class="github-stat-label"><%= l(:label_github_issues_with_pr) %></span>
      </div>
    </div>
  </div>
<% end %>

<%
  signoff     = QaSignoff.for_version(version)
  can_qa      = User.current.logged? && User.current.allowed_to?(:manage_qa_signoffs, version.project)
  issues_total = version.fixed_issues.count
  issues_pass  = IssueTestResult.where(issue_id: version.fixed_issues.ids, result: 'pass').count
  issues_fail  = IssueTestResult.where(issue_id: version.fixed_issues.ids, result: 'fail').count
  issues_blocked = IssueTestResult.where(issue_id: version.fixed_issues.ids, result: 'blocked').count
%>
<div id="qa-release-gate">
  <h3><%= l(:label_qa_release_gate) %></h3>

  <div class="qa-readiness-grid">
    <div class="qa-stat-card">
      <span class="qa-stat-value qa-pass"><%= issues_pass %></span>
      <span class="qa-stat-label"><%= l(:label_qa_issues_pass) %></span>
    </div>
    <div class="qa-stat-card">
      <span class="qa-stat-value qa-fail"><%= issues_fail %></span>
      <span class="qa-stat-label"><%= l(:label_qa_issues_fail) %></span>
    </div>
    <div class="qa-stat-card">
      <span class="qa-stat-value qa-blocked"><%= issues_blocked %></span>
      <span class="qa-stat-label"><%= l(:label_qa_issues_blocked) %></span>
    </div>
    <div class="qa-stat-card">
      <span class="qa-stat-value"><%= issues_total - issues_pass - issues_fail - issues_blocked %></span>
      <span class="qa-stat-label"><%= l(:label_qa_issues_pending) %></span>
    </div>
  </div>

  <div class="qa-signoff-status">
    <% if signoff.approved? %>
      <span class="qa-badge qa-badge-approved"><%= l(:label_qa_status_approved) %></span>
      <span class="qa-signoff-meta">
        <%= l(:label_qa_signed_by) %> <%= signoff.user&.name %>
        <% if signoff.signed_off_at %>· <%= format_time(signoff.signed_off_at) %><% end %>
      </span>
    <% elsif signoff.rejected? %>
      <span class="qa-badge qa-badge-rejected"><%= l(:label_qa_status_rejected) %></span>
      <% if signoff.notes.present? %>
        <span class="qa-signoff-notes"><%= signoff.notes %></span>
      <% end %>
    <% else %>
      <span class="qa-badge qa-badge-pending"><%= l(:label_qa_status_pending) %></span>
    <% end %>
  </div>

  <% if can_qa %>
    <div class="qa-actions">
      <% unless signoff.approved? %>
        <%= form_tag(version_qa_signoffs_approve_path(version.project, version), method: :post, style: 'display:inline') do %>
          <input type="text" name="notes" placeholder="<%= l(:label_qa_notes_placeholder) %>" style="width:300px">
          <button type="submit" class="button-positive"><%= l(:label_qa_approve) %></button>
        <% end %>
      <% end %>
      <% unless signoff.rejected? %>
        <%= form_tag(version_qa_signoffs_reject_path(version.project, version), method: :post, style: 'display:inline') do %>
          <input type="text" name="notes" placeholder="<%= l(:label_qa_reject_reason) %>" style="width:300px">
          <button type="submit" class="button-negative"><%= l(:label_qa_reject) %></button>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

