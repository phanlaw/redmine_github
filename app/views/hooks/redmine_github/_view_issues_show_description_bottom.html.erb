<%
  pull_reqs   = PullRequest.where(issue_id: issue.id).order(created_at: :desc)
  changesets  = issue.changesets.visible
                  .joins(:repository)
                  .where(repositories: { type: 'Repository::Github' })
                  .order(committed_on: :desc)
  deployments = GithubDeployment.for_issue(issue).recent
  test_result = IssueTestResult.find_by(issue_id: issue.id)
  can_qa      = User.current.logged? && User.current.allowed_to?(:manage_qa_signoffs, issue.project)
%>
<% unless pull_reqs.empty? && changesets.empty? && deployments.empty? %>

<div id="github-activity">
  <h3><%= l(:label_github_activity) %></h3>
  <% if pull_reqs.any? %>
  <div class="github-prs">
    <h4><%= l(:label_github_pull_requests) %></h4>
    <table class="list github-pr-list">
      <tbody>
      <% pull_reqs.each do |pr| %>
        <%
          state_key = pr.state
          state_label = l(:"label_github_pr_#{state_key}")
          state_class = "github-pr-state github-pr-#{state_key}"
        %>
        <tr>
          <td><span class="<%= state_class %>"><%= state_label %></span></td>
          <td><%= link_to "##{pr.number}", pr.url, target: '_blank', rel: 'noopener' %></td>
          <td><%= pr.title.presence || pr.url %></td>
          <td class="github-pr-repo"><%= "#{pr.repo_owner}/#{pr.repo_name}" %></td>
          <% if pr.ci_status.present? %>
            <%
              ci_class = "github-ci-badge github-ci-#{pr.ci_status}"
              ci_label = l(:"label_github_ci_#{pr.ci_status}", default: pr.ci_status.capitalize)
            %>
            <td>
              <% if pr.ci_run_url.present? %>
                <%= link_to ci_label, pr.ci_run_url, target: '_blank', rel: 'noopener', class: ci_class %>
              <% else %>
                <span class="<%= ci_class %>"><%= ci_label %></span>
              <% end %>
            </td>
          <% else %>
            <td></td>
          <% end %>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
  <% end %>

  <% if changesets.any? %>
  <div class="github-commits">
    <h4><%= l(:label_github_commits) %></h4>
    <table class="list github-commit-list">
      <tbody>
      <% changesets.each do |cs| %>
        <%
          repo      = cs.repository
          short_rev = cs.revision.to_s.first(8)
          gh_url    = repo.commit_url(cs.revision)
          msg       = cs.comments.to_s.lines.first.to_s.truncate(80)
        %>
        <tr>
          <td class="github-commit-rev">
            <%= link_to short_rev, gh_url, target: '_blank', rel: 'noopener', class: 'github-commit-link' %>
          </td>
          <td><%= msg %></td>
          <td class="github-commit-date"><%= format_date(cs.committed_on) %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
  <% end %>

  <% if deployments.any? %>
  <div class="github-deployments">
    <h4><%= l(:label_github_deployments) %></h4>
    <table class="list github-deployment-list">
      <tbody>
      <% deployments.each do |dep| %>
        <%
          state_class = "github-deploy-badge github-deploy-#{dep.state}"
          state_label = l(:"label_github_deploy_#{dep.state}", default: dep.state.capitalize)
        %>
        <tr>
          <td><span class="github-deploy-env"><%= dep.environment %></span></td>
          <td><span class="<%= state_class %>"><%= state_label %></span></td>
          <td>
            <% if dep.environment_url.present? %>
              <%= link_to dep.environment_url, dep.environment_url, target: '_blank', rel: 'noopener' %>
            <% end %>
          </td>
          <td>
            <% if dep.log_url.present? %>
              <%= link_to l(:label_github_deploy_logs), dep.log_url, target: '_blank', rel: 'noopener' %>
            <% end %>
          </td>
          <td class="github-commit-date"><%= format_time(dep.deployed_at) if dep.deployed_at %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
  <% end %>

  <div class="qa-test-result">
    <h4><%= l(:label_qa_test_result) %></h4>
    <% if test_result %>
      <%
        tr_class = "qa-badge qa-badge-#{test_result.result}"
        tr_label = l(:"label_qa_result_#{test_result.result}", default: test_result.result.capitalize)
      %>
      <span class="<%= tr_class %>"><%= tr_label %></span>
      <% if test_result.fix_rounds > 0 %>
        <span class="qa-fix-rounds"><%= l(:label_qa_fix_rounds, count: test_result.fix_rounds) %></span>
      <% end %>
      <% if test_result.tester_id.present? %>
        <span class="qa-tester"><%= l(:label_qa_tester) %>: <%= test_result.tester&.name %></span>
      <% end %>
      <% if test_result.notes.present? %>
        <p class="qa-notes"><%= test_result.notes %></p>
      <% end %>
    <% else %>
      <span class="qa-badge qa-badge-pending"><%= l(:label_qa_result_pending) %></span>
    <% end %>

    <% if can_qa %>
      <div class="qa-test-actions">
        <%= form_tag(issue_test_result_path(issue.project, issue), method: :post, style: 'display:inline') do %>
          <input type="hidden" name="result" value="pass">
          <button type="submit" class="button-positive"><%= l(:label_qa_mark_pass) %></button>
        <% end %>
        <%= form_tag(issue_test_result_path(issue.project, issue), method: :post, style: 'display:inline') do %>
          <input type="hidden" name="result" value="fail">
          <input type="text" name="notes" placeholder="<%= l(:label_qa_notes_placeholder) %>" style="width:200px">
          <button type="submit" class="button-negative"><%= l(:label_qa_mark_fail) %></button>
        <% end %>
        <%= form_tag(issue_test_result_path(issue.project, issue), method: :post, style: 'display:inline') do %>
          <input type="hidden" name="result" value="blocked">
          <input type="text" name="notes" placeholder="<%= l(:label_qa_notes_placeholder) %>" style="width:200px">
          <button type="submit"><%= l(:label_qa_mark_blocked) %></button>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
<% end %>
