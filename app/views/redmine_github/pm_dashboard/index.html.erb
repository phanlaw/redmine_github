<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'redmine_github', plugin: :redmine_github %>
<% end %>

<h2><%= l(:label_pm_dashboard) %></h2>

<div class="pm-selection-bar">
  <% form_with local: true do |f| %>
    <div class="pm-selection-group">
      <label><%= l(:label_pm_project) %></label>
      <%= select_tag :project_id,
          options_from_collection_for_select(Project.visible.sorted, :id, :name, @project.id),
          onchange: "window.location = this.value ? '/projects/' + this.value + '/pm_dashboard' : '#'" %>
    </div>
    <div class="pm-selection-group">
      <label><%= l(:label_pm_sprint) %></label>
      <%= select_tag :sprint_id,
          options_from_collection_for_select(@versions, :id, :name, @selected_sprint&.id),
          onchange: "window.location = '?sprint_id=' + this.value;" %>
    </div>
  <% end %>
</div>

<% if @versions.empty? %>
  <p class="nodata"><%= l(:label_no_data) %></p>
<% elsif !@selected_sprint %>
  <p class="notice">Select a sprint to view dashboard.</p>
<% else %>
  <% ps       = @sprint_stats %>
  <% qs       = @qa_stats %>
  <% rg       = @release_gate %>
  <% workflow = @approval_workflow %>

  <%# Determine approval state %>
  <% qa_pending = workflow[:qa_approval].pending? %>
  <% pm_pending = workflow[:pm_approval].pending? && workflow[:qa_approval].approved? %>

  <%# Collect what's blocking a release %>
  <%
    blocking = []
    blocking << "completion #{ps[:completion_rate]}% (need ≥#{RedmineGithub::SprintPmStats::COMPLETION_THRESHOLD}%)"  unless ps[:completion_ok]
    blocking << "bug rate #{ps[:bug_rate]}% (need <#{RedmineGithub::SprintPmStats::BUG_RATE_THRESHOLD}%)"              unless ps[:bug_rate_ok]
    blocking << "test coverage #{qs[:execution_rate]}% (need ≥#{RedmineGithub::QaGateStats::EXECUTION_RATE_THRESHOLD}%)" unless qs[:execution_rate_ok]
    blocking << "#{qs[:open_blockers]} open #{'blocker'.pluralize(qs[:open_blockers])}"                                unless qs[:blockers_ok]
    blocking << "QA sign-off pending"                                                                                  unless qs[:signoff_ok]
  %>

  <%# ── Decision banner ── %>
  <% if rg[:ready] && workflow[:chain_complete] %>
    <div class="pm-decision pm-go">
      <span class="pm-decision-verdict">✓ READY FOR PRODUCTION</span>
      <span class="pm-decision-meta"><%= @selected_sprint.name %> &nbsp;·&nbsp; QA &amp; PM approved</span>
    </div>
  <% elsif (rg[:ready] || rg[:risky]) && (qa_pending || pm_pending) %>
    <div class="pm-decision pm-awaiting">
      <span class="pm-decision-verdict">⏳ AWAITING APPROVAL</span>
      <span class="pm-decision-meta"><%= @selected_sprint.name %> &nbsp;·&nbsp; <%= qa_pending ? 'Waiting for QA sign-off' : 'Waiting for PM approval' %></span>
    </div>
  <% elsif rg[:risky] %>
    <div class="pm-decision pm-risky">
      <span class="pm-decision-verdict">⚠ RISKY — review before releasing</span>
      <span class="pm-decision-meta"><%= @selected_sprint.name %> &nbsp;·&nbsp; <%= blocking.join(' · ') %></span>
    </div>
  <% else %>
    <div class="pm-decision pm-nogo">
      <span class="pm-decision-verdict">✗ NOT READY &mdash; <%= blocking.size %> <%= 'issue'.pluralize(blocking.size) %> blocking</span>
      <span class="pm-decision-meta"><%= @selected_sprint.name %> &nbsp;·&nbsp; <%= blocking.join(' · ') %></span>
    </div>
  <% end %>

  <%# ── Action list: what needs to happen before release ── %>
  <% if blocking.any? || qa_pending || pm_pending %>
    <h4 style="margin-top:1.2em">To release this sprint:</h4>
    <ul class="pm-actions">
      <% unless ps[:completion_ok] %>
        <li>
          <%= link_to "View closed issues →", project_pm_dashboard_closed_issues_path(@project, sprint_id: @selected_sprint.id) %>
          — <b><%= ps[:closed] %>/<%= ps[:total] %> tasks done (<%= ps[:completion_rate] %>%)</b>
          <span class="pm-target">need ≥ <%= RedmineGithub::SprintPmStats::COMPLETION_THRESHOLD %>%</span>
        </li>
      <% end %>
      <% unless ps[:bug_rate_ok] %>
        <li>
          <b>Bug rate <%= ps[:bug_rate] %>%</b>
          <span class="pm-target">need &lt; <%= RedmineGithub::SprintPmStats::BUG_RATE_THRESHOLD %>%</span>
          — reduce open bugs in this sprint
        </li>
      <% end %>
      <% unless qs[:execution_rate_ok] %>
        <li>
          <%= link_to "View untested issues →", project_pm_dashboard_failed_tests_path(@project, sprint_id: @selected_sprint.id) %>
          — <b><%= qs[:tested] %>/<%= qs[:total] %> tested (<%= qs[:execution_rate] %>%)</b>
          <span class="pm-target">need ≥ <%= RedmineGithub::QaGateStats::EXECUTION_RATE_THRESHOLD %>%</span>
        </li>
      <% end %>
      <% unless qs[:blockers_ok] %>
        <li>
          <%= link_to "View #{qs[:open_blockers]} open #{'blocker'.pluralize(qs[:open_blockers])} →", project_pm_dashboard_blockers_path(@project, sprint_id: @selected_sprint.id) %>
          <span class="pm-target">must be 0 to release</span>
        </li>
      <% end %>
      <% if qa_pending %>
        <li>
          <b>QA sign-off required</b> &nbsp;
          <%= button_to 'Approve', version_release_approvals_approve_qa_path(@project, @selected_sprint), method: :post, data: { confirm: 'Approve QA?' } %>
          <%= button_to 'Reject',  version_release_approvals_reject_qa_path(@project, @selected_sprint),  method: :post, data: { confirm: 'Reject QA?' } %>
        </li>
      <% end %>
      <% if pm_pending %>
        <li>
          <b>PM release approval required</b> &nbsp;
          <%= button_to 'Approve Release', version_release_approvals_approve_pm_path(@project, @selected_sprint), method: :post, data: { confirm: 'Approve release to production?' } %>
          <%= button_to 'Reject',          version_release_approvals_reject_pm_path(@project, @selected_sprint), method: :post, data: { confirm: 'Reject release?' } %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <%# ── Sprint metrics at a glance ── %>
  <p style="margin-top:1.2em">
    <b>Sprint metrics</b> &nbsp;
    <%= link_to '⚙ Configure thresholds', edit_project_threshold_path(@project) %>
  </p>
  <table class="list">
    <thead>
      <tr>
        <th>Tasks done</th>
        <th>Completion</th>
        <th>Bug rate</th>
        <th>Delay rate</th>
        <th>Avg cycle</th>
        <th>Tests</th>
        <th>Blockers</th>
        <th>QA sign-off</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><%= ps[:closed] %> / <%= ps[:total] %></td>
        <td class="<%= ps[:completion_ok] ? '' : 'pm-fail-cell' %>">
          <%= link_to "#{ps[:completion_rate]}%", project_pm_dashboard_closed_issues_path(@project, sprint_id: @selected_sprint.id) %>
          <small class="pm-target">≥ <%= RedmineGithub::SprintPmStats::COMPLETION_THRESHOLD %>%</small>
        </td>
        <td class="<%= ps[:bug_rate_ok] ? '' : 'pm-fail-cell' %>">
          <%= ps[:bug_rate] %>% <small class="pm-target">&lt; <%= RedmineGithub::SprintPmStats::BUG_RATE_THRESHOLD %>%</small>
        </td>
        <td class="<%= ps[:delay_rate_ok] ? '' : 'pm-fail-cell' %>">
          <%= link_to "#{ps[:delay_rate]}%", project_pm_dashboard_delayed_tasks_path(@project, sprint_id: @selected_sprint.id) %>
          <small class="pm-target">&lt; <%= RedmineGithub::SprintPmStats::DELAY_RATE_THRESHOLD %>%</small>
        </td>
        <td><%= ps[:avg_cycle_days] ? "#{ps[:avg_cycle_days]}d" : '—' %></td>
        <td class="<%= qs[:execution_rate_ok] ? '' : 'pm-fail-cell' %>">
          <%= link_to "#{qs[:execution_rate]}%", project_pm_dashboard_failed_tests_path(@project, sprint_id: @selected_sprint.id) %>
          <small class="pm-target">≥ <%= RedmineGithub::QaGateStats::EXECUTION_RATE_THRESHOLD %>%</small><br>
          <small><%= qs[:passed] %> pass · <%= qs[:failed] %> fail · <%= qs[:blocked_count] %> blocked</small>
        </td>
        <td class="<%= qs[:blockers_ok] ? '' : 'pm-fail-cell' %>">
          <%= link_to qs[:open_blockers].to_s, project_pm_dashboard_blockers_path(@project, sprint_id: @selected_sprint.id) %>
          <small class="pm-target">(must be 0)</small>
        </td>
        <td>
          <% if qs[:signoff_status] == 'approved' %><span style="color:#2a7d2a">✓ Approved</span>
          <% elsif qs[:signoff_status] == 'rejected' %><span style="color:#c0392b">✗ Rejected</span>
          <% else %>Pending<% end %>
        </td>
      </tr>
    </tbody>
  </table>

  <%# ── Blockers ── %>
  <% blockers = @sprint_stats[:blockers] || [] %>
  <% if blockers.any? %>
    <h4 style="margin-top:1.2em"><%= l(:label_pm_blockers) %> (<%= blockers.size %>)</h4>
    <table class="list">
      <thead>
        <tr><th>ID</th><th>Subject</th><th>Assignee</th><th>Open since</th><th>Duration</th></tr>
      </thead>
      <tbody>
        <% blockers.sort_by { |b| b[:created_on] || Time.current }.each do |b| %>
          <tr>
            <td><%= link_to "##{b[:id]}", issue_path(b[:id]) %></td>
            <td><%= link_to b[:subject], issue_path(b[:id]) %></td>
            <td><%= b[:assignee] || '—' %></td>
            <td><%= time_tag b[:created_on], format: :short if b[:created_on] %></td>
            <td><span class="pm-duration"><%= distance_of_time_in_words(b[:created_on] || Time.current, Time.current) %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <%# ── Trend analysis ── %>
  <% trends = @trend_analysis[:sprints] %>
  <% if trends.size > 1 %>
    <h4 style="margin-top:1.2em"><%= l(:label_pm_trend_analysis) %></h4>
    <table class="list">
      <thead>
        <tr><th>Sprint</th><th>Done</th><th>Completion</th><th>Avg cycle (days)</th><th>Bug rate</th></tr>
      </thead>
      <tbody>
        <% trends.each do |s| %>
          <tr>
            <td><%= link_to s[:name], project_pm_dashboard_path(@project, sprint_id: s[:id]) %></td>
            <td><%= s[:closed_issues] %> / <%= s[:total_issues] %></td>
            <td><%= s[:completion_rate].round %>%</td>
            <td><%= s[:cycle_time].round(1) %></td>
            <td><%= s[:bug_rate].round(1) %>%</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <%# ── Audit trail ── %>
  <% timeline = @audit_trail[:timeline] %>
  <% if timeline.any? %>
    <h4 style="margin-top:1.2em"><%= l(:label_pm_audit_trail) %></h4>
    <ul class="pm-audit">
      <% timeline.each do |e| %>
        <li>
          <b><%= e[:user] %></b> (<%= e[:role] %>) <%= e[:action] %>d
          <% if e[:notes].present? %>&nbsp;&mdash;&nbsp;<em>"<%= e[:notes] %>"</em><% end %>
          &nbsp;<span class="pm-duration"><%= time_ago_in_words(e[:timestamp]) %> ago</span>
          <small>(<%= time_tag e[:timestamp], format: :short %>)</small>
        </li>
      <% end %>
    </ul>
  <% end %>

<% end %>
