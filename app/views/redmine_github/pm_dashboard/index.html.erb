<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'redmine_github', plugin: :redmine_github %>
<% end %>

<h2><%= l(:label_pm_dashboard) %></h2>

<div class="pm-selection-bar">
  <% form_with local: true do |f| %>
    <div class="pm-selection-group">
      <label><%= l(:label_pm_project) %></label>
      <%= select_tag :project_id, 
          options_from_collection_for_select(Project.visible.sorted, :id, :name, @project.id),
          onchange: "window.location = this.value ? '/projects/' + this.value + '/pm_dashboard' : '#'" %>
    </div>

    <div class="pm-selection-group">
      <label><%= l(:label_pm_sprint) %></label>
      <%= select_tag :sprint_id,
          options_from_collection_for_select(@versions, :id, :name, @selected_sprint&.id),
          onchange: "window.location = '?sprint_id=' + this.value;" %>
    </div>
  <% end %>
</div>

<% if @versions.empty? %>
  <p class="nodata"><%= l(:label_no_data) %></p>
<% elsif !@selected_sprint %>
  <p class="notice">Select a sprint to view dashboard.</p>
<% else %>
  <% ps = @sprint_stats %>
  <% qs = @qa_stats %>
      <h3>
        <%= link_to @selected_sprint.name, settings_project_path(@project, tab: 'versions') %>
        <span class="pm-sprint-status <%= @selected_sprint.status == 'open' ? 'pm-status-open' : 'pm-status-closed' %>">
          <%= @selected_sprint.status.upcase %>
        </span>
        <% if qs[:release_ready] %>
          <span class="pm-gate-badge pm-gate-go">✓ READY FOR PRODUCTION</span>
        <% else %>
          <span class="pm-gate-badge pm-gate-nogo">⚠ NOT READY</span>
        <% end %>
      </h3>

      <div class="pm-metrics-grid">

        <%# ── Sprint Success Metrics ── %>
        <div class="pm-metric-group">
          <h4><%= l(:label_pm_success_metrics) %></h4>

          <div class="pm-metric <%= ps[:completion_ok] ? 'pm-ok' : 'pm-fail' %>">
            <%= link_to project_pm_dashboard_closed_issues_path(@project, sprint_id: @selected_sprint.id), class: 'pm-metric-link' do %>
              <span class="pm-metric-label"><%= l(:label_pm_completion_rate) %></span>
              <span class="pm-metric-value"><%= ps[:completion_rate] %>%</span>
              <span class="pm-metric-target">(target ≥ <%= RedmineGithub::SprintPmStats::COMPLETION_THRESHOLD %>%)</span>
              <span class="pm-metric-badge"><%= ps[:completion_ok] ? '✓' : '✗' %></span>
            <% end %>
          </div>

          <div class="pm-metric <%= ps[:bug_rate_ok] ? 'pm-ok' : 'pm-fail' %>">
            <span class="pm-metric-label"><%= l(:label_pm_bug_rate) %></span>
            <span class="pm-metric-value"><%= ps[:bug_rate] %>%</span>
            <span class="pm-metric-target">(target &lt; <%= RedmineGithub::SprintPmStats::BUG_RATE_THRESHOLD %>%)</span>
            <span class="pm-metric-badge"><%= ps[:bug_rate_ok] ? '✓' : '✗' %></span>
          </div>

          <div class="pm-metric <%= ps[:delay_rate_ok] ? 'pm-ok' : 'pm-fail' %>">
            <%= link_to project_pm_dashboard_delayed_tasks_path(@project, sprint_id: @selected_sprint.id), class: 'pm-metric-link' do %>
              <span class="pm-metric-label"><%= l(:label_pm_delay_rate) %></span>
              <span class="pm-metric-value"><%= ps[:delay_rate] %>%</span>
              <span class="pm-metric-target">(target &lt; <%= RedmineGithub::SprintPmStats::DELAY_RATE_THRESHOLD %>%)</span>
              <span class="pm-metric-badge"><%= ps[:delay_rate_ok] ? '✓' : '✗' %></span>
            <% end %>
          </div>

          <div class="pm-metric pm-neutral">
            <span class="pm-metric-label"><%= l(:label_pm_avg_cycle_time) %></span>
            <span class="pm-metric-value"><%= ps[:avg_cycle_days] ? "#{ps[:avg_cycle_days]}d" : '—' %></span>
            <span class="pm-metric-target"><%= ps[:closed] %> / <%= ps[:total] %> tasks closed</span>
          </div>
        </div>

        <%# ── QA Release Gate ── %>
        <div class="pm-metric-group">
          <h4><%= l(:label_pm_qa_gate) %></h4>

          <div class="pm-metric <%= qs[:execution_rate_ok] ? 'pm-ok' : 'pm-fail' %>">
            <span class="pm-metric-label"><%= l(:label_pm_test_execution_rate) %></span>
            <span class="pm-metric-value"><%= qs[:execution_rate] %>%</span>
            <span class="pm-metric-target">(<%= qs[:tested] %>/<%= qs[:total] %> tested, target ≥ <%= RedmineGithub::QaGateStats::EXECUTION_RATE_THRESHOLD %>%)</span>
            <span class="pm-metric-badge"><%= qs[:execution_rate_ok] ? '✓' : '✗' %></span>
          </div>

          <div class="pm-metric <%= qs[:blockers_ok] ? 'pm-ok' : 'pm-fail' %>">
            <%= link_to project_pm_dashboard_blockers_path(@project, sprint_id: @selected_sprint.id), class: 'pm-metric-link' do %>
              <span class="pm-metric-label"><%= l(:label_pm_open_blockers) %></span>
              <span class="pm-metric-value"><%= qs[:open_blockers] %></span>
              <span class="pm-metric-target">(target = 0)</span>
              <span class="pm-metric-badge"><%= qs[:blockers_ok] ? '✓' : '✗' %></span>
            <% end %>
          </div>

          <div class="pm-metric">
            <%= link_to project_pm_dashboard_failed_tests_path(@project, sprint_id: @selected_sprint.id), class: 'pm-metric-link' do %>
              <span class="pm-metric-label"><%= l(:label_pm_test_results) %></span>
              <span class="pm-metric-value">
                <span class="qa-badge qa-pass"><%= qs[:passed] %> Pass</span>
                <span class="qa-badge qa-fail"><%= qs[:failed] %> Fail</span>
                <span class="qa-badge qa-blocked"><%= qs[:blocked_count] %> Blocked</span>
              </span>
            <% end %>
          </div>

          <div class="pm-metric <%= qs[:signoff_ok] ? 'pm-ok' : (qs[:signoff_status] == 'rejected' ? 'pm-fail' : 'pm-pending') %>">
            <span class="pm-metric-label"><%= l(:label_pm_qa_signoff) %></span>
            <span class="pm-metric-value">
              <% if qs[:signoff_status] == 'approved' %>
                <span class="qa-badge qa-pass">✓ Approved</span>
              <% elsif qs[:signoff_status] == 'rejected' %>
                <span class="qa-badge qa-fail">✗ Rejected</span>
              <% else %>
                <span class="qa-badge">Pending</span>
              <% end %>
            </span>
            <span class="pm-metric-badge"><%= qs[:signoff_ok] ? '✓' : '—' %></span>
          </div>

          <% if qs[:release_ready] %>
            <div class="pm-release-go">
              🚀 <%= l(:label_pm_release_ready) %>
            </div>
          <% else %>
            <div class="pm-release-nogo">
              <strong><%= l(:label_pm_release_blocked) %></strong>
              <ul>
                <%= content_tag(:li, l(:label_pm_need_execution_rate))  unless qs[:execution_rate_ok] %>
                <%= content_tag(:li, l(:label_pm_need_no_blockers))     unless qs[:blockers_ok] %>
                <%= content_tag(:li, l(:label_pm_need_qa_signoff))      unless qs[:signoff_ok] %>
              </ul>
            </div>
          <% end %>
        </div>

      </div><%# /pm-metrics-grid %>

      <%# ── Sprint Health Summary ── %>
      <div class="pm-metric-group">
        <h4><%= l(:label_pm_health_summary) %></h4>
        <% hs = @health_summary %>

        <div class="pm-metric pm-health-grid">
          <div class="pm-health-item pm-health-<%= hs[:completion_rate][:status] %>">
            <span class="pm-health-label">Completion</span>
            <span class="pm-health-value"><%= hs[:completion_rate][:value] %>%</span>
            <span class="pm-health-status"><%= hs[:completion_rate][:status].to_s.upcase %></span>
          </div>

          <div class="pm-health-item pm-health-<%= hs[:bug_rate][:status] %>">
            <span class="pm-health-label">Bug Rate</span>
            <span class="pm-health-value"><%= hs[:bug_rate][:value] %>%</span>
            <span class="pm-health-status"><%= hs[:bug_rate][:status].to_s.upcase %></span>
          </div>

          <div class="pm-health-item pm-health-<%= hs[:delay_rate][:status] %>">
            <span class="pm-health-label">Delay Rate</span>
            <span class="pm-health-value"><%= hs[:delay_rate][:value] %>%</span>
            <span class="pm-health-status"><%= hs[:delay_rate][:status].to_s.upcase %></span>
          </div>

          <div class="pm-health-item pm-health-<%= hs[:cycle_time][:status] %>">
            <span class="pm-health-label">Avg Cycle Time</span>
            <span class="pm-health-value"><%= number_with_precision(hs[:cycle_time][:value] || 0, precision: 1) %> days</span>
            <span class="pm-health-status"><%= hs[:cycle_time][:status].to_s.upcase %></span>
          </div>
        </div>

        <div class="pm-health-overall pm-health-<%= hs[:overall_status] %>">
          <strong>Overall Sprint Health: <%= hs[:overall_status].to_s.upcase %></strong>
          <p>Based on configurable thresholds. <%= link_to 'Configure', '#' %></p>
        </div>
      </div>

      <%# ── Blocker Visibility ── %>
      <% blockers = @sprint_stats[:blockers] || [] %>
      <% if blockers.any? %>
        <div class="pm-blocker-visibility">
          <h4><%= l(:label_pm_blockers) %></h4>
          <table class="pm-blocker-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Subject</th>
                <th>Assignee</th>
                <th>Blocked Since</th>
                <th>Duration</th>
              </tr>
            </thead>
            <tbody>
              <% blockers.sort_by { |b| b[:created_on] || Time.current }.each do |blocker| %>
                <tr>
                  <td><%= link_to "##{blocker[:id]}", issue_path(blocker[:id]) %></td>
                  <td><%= link_to blocker[:subject], issue_path(blocker[:id]) %></td>
                  <td><%= blocker[:assignee] %></td>
                  <td><%= time_tag blocker[:created_on], format: :short if blocker[:created_on] %></td>
                  <td><span class="pm-duration"><%= distance_of_time_in_words(blocker[:created_on] || Time.current, Time.current) %></span></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>

<% end %>
